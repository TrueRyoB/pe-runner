# --- Discord ---
DISCORD_TOKEN=your-bot-token
# Slash commands are registered to this guild for instant availability.
GUILD_ID=123456789012345678
# Optional: only members with this role (or Manage Server perm) can create contests.
ORGANIZER_ROLE_ID=

# --- Project Euler bot account session ---
# PE login has a CAPTCHA, so we do NOT log in programmatically.
# Log in once in a browser with "Keep me logged in", then copy the cookies here.
# Extract from DevTools > Application > Cookies for projecteuler.net.
PE_SESSION_COOKIE=PHPSESSID=xxxxxxxxxxxxx
# The persistent "remember me" cookie (name varies, often 'keep_alive'). Optional but
# recommended so the session survives PHPSESSID expiry.
PE_KEEP_ALIVE_COOKIE=
# The bot's own PE username (used to read the full problem catalog + difficulty).
PE_BOT_USERNAME=your-pe-username

# --- Misc ---
# Timezone for interpreting contest start times you type.
TIMEZONE=Asia/Tokyo
DB_PATH=pe_runner.db
# Max friends per PE account (safeguard warns as registrations approach this).
FRIEND_LIMIT=64
