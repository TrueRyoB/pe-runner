# --- Discord ---
DISCORD_TOKEN=your-bot-token
# Slash commands are registered to this guild for instant availability.
GUILD_ID=123456789012345678
# Optional: only members with this role (or Manage Server perm) can create contests.
ORGANIZER_ROLE_ID=
# Only this account can delete the bot's messages (username or numeric user ID).
OWNER=trueryob

# --- Project Euler bot account session ---
# PE login has a CAPTCHA, so we do NOT log in programmatically. Seed from a
# browser logged into the BOT's PE account with "Keep me logged in".
#
# PE auth needs BOTH PHPSESSID and keep_alive. keep_alive ROTATES on use, so this
# is only the initial SEED — after first use the bot persists the rotating jar to
# pe_cookies.pkl and keeps itself logged in. Don't keep browsing PE as the bot
# account elsewhere or you'll rotate its token out. To re-seed, just edit this
# file (the bot detects the newer mtime and re-seeds).
#
# EASIEST: DevTools > Network > reload > click any projecteuler.net request >
# Request Headers > copy the whole `Cookie:` value into PE_COOKIE.
PE_COOKIE=PHPSESSID=xxxxx; keep_alive=yyyyy
# Alternative to PE_COOKIE: set these two individually. A bare value (no "name=")
# is treated as PHPSESSID / keep_alive respectively.
PE_SESSION_COOKIE=
PE_KEEP_ALIVE_COOKIE=
# The bot's own PE username (used to read the full problem catalog + difficulty).
PE_BOT_USERNAME=

# --- Persistent DB (Turso/libSQL) ---
# Optional. If BOTH are set, data survives restarts (registrations, contests,
# solves, votes, ratings). Empty => local SQLite (ephemeral on Render). Turso's
# free tier needs no credit card. Get these from the Turso dashboard.
DB_URL=libsql://your-db.turso.io
DB_TOKEN_RW=your-read-write-token

# --- Misc ---
# Timezone for interpreting contest start times you type.
TIMEZONE=Asia/Tokyo
DB_PATH=pe_runner.db
# Max friends per PE account (safeguard warns as registrations approach this).
FRIEND_LIMIT=64
