# Copy to .env and fill in. On Render, set these as Environment variables instead.

# --- Discord ---
# Developer Portal > your app > Bot > Reset Token
DISCORD_TOKEN=your-bot-token
# The server (guild) to register slash commands to. Enable Developer Mode, then
# right-click the server > Copy Server ID.
GUILD_ID=123456789012345678
# Only this account may delete the bot's messages (Discord username or numeric ID).
OWNER=your-discord-username

# --- Project Euler bot account session ---
# PE login has a CAPTCHA, so we do NOT log in programmatically. Log into the BOT's
# PE account in a browser ("Keep me logged in"), then paste its cookie here.
#
# RECOMMENDED: DevTools > Network > reload > click any projecteuler.net request >
# Request Headers > copy the WHOLE `Cookie:` value into PE_COOKIE. It contains the
# real session cookie `__Host-PHPSESSID` and `keep_alive`.
PE_COOKIE=__Host-PHPSESSID=xxxxx; keep_alive=yyyyy
# Alternative to PE_COOKIE: set these individually. A bare value (no "name=") is
# treated as the session cookie / keep_alive respectively.
PE_SESSION_COOKIE=
PE_KEEP_ALIVE_COOKIE=
# The bot's own PE username (used to read the full problem catalog + difficulty).
PE_BOT_USERNAME=your-pe-username

# --- Persistent DB (Turso / libSQL) — optional but recommended for real use ---
# If BOTH are set, data survives restarts (registrations, contests, solves, votes,
# ratings). Empty => local SQLite (ephemeral on Render). Turso free tier needs no
# credit card. Create a DB in the Turso dashboard and copy its URL + RW token.
DB_URL=libsql://your-db.turso.io
DB_TOKEN_RW=your-read-write-token

# --- Misc ---
# Timezone for interpreting contest start times you type.
TIMEZONE=Asia/Tokyo
# Local SQLite path (used only when DB_URL/DB_TOKEN_RW are empty).
DB_PATH=pe_runner.db
# Warn as registrations approach the PE friend cap (64 per account).
FRIEND_LIMIT=64
